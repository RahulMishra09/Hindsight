# =============================================================================
# Hindsight — Environment Variables Reference
# =============================================================================
# Copy this file to .env and fill in real values for local development.
# NEVER commit .env (it is gitignored). This file contains NO real values.
#
# All variables are consumed by app/core/settings.py (pydantic-settings).
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------

# Runtime environment: "development" | "staging" | "production"
ENV=development

# Secret key for JWT signing (HS256). Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=

# JWT token expiry in minutes (default: 60)
JWT_EXPIRY_MINUTES=60

# ---------------------------------------------------------------------------
# PostgreSQL 16 + pgvector
# ---------------------------------------------------------------------------

# Full async DSN for SQLAlchemy + asyncpg
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://hindsight:hindsight@localhost:5432/hindsight

# Alembic uses a sync DSN (psycopg2 or psycopg3) for migrations
# Format: postgresql+psycopg://user:password@host:port/dbname
DATABASE_URL_SYNC=postgresql+psycopg://hindsight:hindsight@localhost:5432/hindsight

# Connection pool settings
DB_POOL_SIZE=10
DB_POOL_MAX_OVERFLOW=20

# ---------------------------------------------------------------------------
# Redis 7 Streams
# ---------------------------------------------------------------------------

# Redis connection URL for event bus and caching
REDIS_URL=redis://localhost:6379/0

# Consumer ID prefix (appended with PID for uniqueness)
REDIS_CONSUMER_PREFIX=hindsight

# ---------------------------------------------------------------------------
# Crawler
# ---------------------------------------------------------------------------

# Seconds between requests to the same host (politeness delay)
CRAWLER_POLITENESS_INTERVAL=2.0

# HTTP request timeout in seconds
CRAWLER_TIMEOUT=30

# User-Agent header sent by the crawler
CRAWLER_USER_AGENT=HindsightBot/0.1

# Maximum concurrent crawler requests
CRAWLER_MAX_CONCURRENCY=20

# ---------------------------------------------------------------------------
# Deduper (MinHash LSH)
# ---------------------------------------------------------------------------

# Jaccard similarity threshold for near-duplicate detection
DEDUP_JACCARD_THRESHOLD=0.85

# Number of MinHash permutations
DEDUP_NUM_PERM=128

# LSH band size (num_perm / band_size = number of bands)
DEDUP_BAND_SIZE=4

# ---------------------------------------------------------------------------
# Classifier
# ---------------------------------------------------------------------------

# Path to trained model directory (must contain config.json + model weights)
CLASSIFIER_MODEL_DIR=models/deberta-taxonomy/best

# Max sequence length for tokenizer
CLASSIFIER_MAX_LENGTH=512

# ---------------------------------------------------------------------------
# ML Models
# ---------------------------------------------------------------------------

# Hugging Face Hub token (for downloading gated models)
HF_TOKEN=

# Local path where downloaded models are cached
# Default: ./models  (gitignored)
MODEL_CACHE_DIR=./models

# ---------------------------------------------------------------------------
# Hugging Face Hub — dataset/model publishing (used in CI Week 3/5)
# ---------------------------------------------------------------------------

# HF repository IDs for release artefacts
HF_DATASET_REPO=

HF_MODEL_REPO=

# ---------------------------------------------------------------------------
# Weights & Biases — training experiment tracking
# ---------------------------------------------------------------------------

# W&B API key
WANDB_API_KEY=

# W&B project name
WANDB_PROJECT=hindsight

# W&B entity (username or team)
WANDB_ENTITY=

# Set to "disabled" in CI to skip W&B logging
WANDB_MODE=online

# ---------------------------------------------------------------------------
# External APIs
# ---------------------------------------------------------------------------

# Groq API key (used for LLM-assisted annotation in ml/ pipeline)
GROQ_API_KEY=

# ---------------------------------------------------------------------------
# Observability (structured logging only — no Prometheus/Grafana in v1)
# ---------------------------------------------------------------------------

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Log format: "json" (production) | "text" (development)
LOG_FORMAT=text
